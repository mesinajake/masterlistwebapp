# Master List Web App — Environment Variables
# Copy this file to .env.local and fill in your values.

# ─── PostgreSQL ────────────────────────────────────────
# Connection string for your local or remote PostgreSQL database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/masterlist_db

# ─── Lark OAuth (International / Larksuite) ────────────
# Get these from Lark Developer Console → Credentials & Basic Info
LARK_APP_ID=cli_your_app_id
LARK_APP_SECRET=your_app_secret_here
# Must match redirect URL registered in Developer Console → Security Settings
LARK_REDIRECT_URI=http://localhost:3000/api/auth/lark/callback

# ─── JWT ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-random-256-bit-hex-string

# ─── Internal API ─────────────────────────────────────
# Used for fire-and-forget calls between API routes (e.g. vectorization)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_API_SECRET=replace-with-a-random-256-bit-hex-string

# ─── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
